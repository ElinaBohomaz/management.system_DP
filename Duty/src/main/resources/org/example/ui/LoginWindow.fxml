                    <DropShadow offsetX="0" offsetY="10" radius="20" color="#00000025"/>
                </effect>

                <StackPane alignment="CENTER">
                    <Rectangle width="100" height="100" arcWidth="22" arcHeight="22" style="-fx-fill: linear-gradient(to bottom right, #1565c0, #0d47a1); -fx-effect: dropshadow(gaussian, #1565c040, 10, 0, 0, 5);"/>
