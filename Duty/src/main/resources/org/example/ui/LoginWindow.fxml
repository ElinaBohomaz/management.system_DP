                    <VBox spacing="6">
                        <Label text="Логін" style="-fx-text-fill: #546e7a; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <TextField fx:id="loginField" promptText="Введіть ваш логін" style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e0e0e0; -fx-border-width: 1.5; -fx-padding: 14 14; -fx-font-size: 14px; -fx-background-color: #fafbfc;">
                            <padding>
                                <Insets left="14" right="14"/>
                            </padding>
                        </TextField>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Пароль" style="-fx-text-fill: #546e7a; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                        <PasswordField fx:id="passwordField" promptText="Введіть ваш пароль" style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e0e0e0; -fx-border-width: 1.5; -fx-padding: 14 14; -fx-font-size: 14px; -fx-background-color: #fafbfc;">
                            <padding>
                                <Insets left="14" right="14"/>
                            </padding>
                        </PasswordField>
                    </VBox>
                </VBox>

                <Button fx:id="loginButton" text="Увійти" onAction="#handleLogin" style="-fx-background-color: #1565c0; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 12; -fx-padding: 14 0;" prefWidth="380" maxWidth="380">
